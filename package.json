{
  "name": "nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nuxt build",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nuxt dev",
    "generate": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare && (husky || true)",
    "optimize:images": "node scripts/optimize-hero-images.mjs",
    "seo:meta-smoke": "node scripts/seo-meta-smoke.mjs",
    "deploy:production": "node scripts/deploy-production.mjs",
    "lint": "eslint --ext .js,.mjs,.ts,.vue --max-warnings 0 .",
    "lint:fix": "eslint --ext .js,.mjs,.ts,.vue --fix .",
    "format": "prettier --check \"**/*.{js,mjs,ts,vue,json,md,css}\"",
    "format:fix": "prettier --write \"**/*.{js,mjs,ts,vue,json,md,css}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/eslint-config": "^0.5.7",
    "baseline-browser-mapping": "^2.10.27",
    "cross-env": "^10.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.1"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/scripts": "^0.12.1",
    "@nuxtjs/i18n": "^10.1.0",
    "@pinia/nuxt": "^0.11.2",
    "@tailwindcss/vite": "^4.1.13",
    "@unhead/vue": "^2.0.17",
    "flowbite": "^3.1.2",
    "isomorphic-dompurify": "^3.12.0",
    "nuxt": "^4.4.8",
    "nuxt-swiper": "^2.0.1",
    "pinia": "^3.0.3",
    "tailwindcss": "^4.1.13",
    "vue": "^3.5.22",
    "vue-router": "^4.5.1"
  },
  "lint-staged": {
    "*.{js,mjs,ts,vue}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
