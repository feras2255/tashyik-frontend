[variables]
NIXPACKS_NODE_VERSION = "22"

[phases.setup]
nixPkgs = ["nodejs_22", "npm-10_x"]

[phases.install]
cmds = [
  "rm -rf node_modules package-lock.json pnpm-lock.yaml",
  "npx pnpm@9 install --no-frozen-lockfile"
]

[phases.build]
# Re-run install after Nixpacks re-COPY between phases (keeps node_modules for nuxt/vite).
cmds = [
  "rm -rf package-lock.json pnpm-lock.yaml",
  "npx pnpm@9 install --no-frozen-lockfile",
  "NODE_ENV=production npx pnpm@9 run build"
]

[start]
cmd = "NODE_ENV=production npm run start"
